{{!< default}}
{{#post}}

<div class="prog-source" hidden>{{content}}</div>

<header class="page-hero center">
    <div class="container">
        <div class="page-hero-inner reveal">
            <nav class="breadcrumb"><a href="{{@site.url}}">Home</a> <span>/</span> <a href="/programs/">Programs</a> <span>/</span> <span>{{title}}</span></nav>
            <span class="eyebrow center">Community Health</span>
            <h1>{{title}}</h1>
            <p>{{#if custom_excerpt}}{{custom_excerpt}}{{else}}Community health for all — camps, blood drives and ambulance services since 2008.{{/if}}</p>
        </div>
    </div>
</header>

<section class="section">
    <div class="container">
        <div class="split">
            <div class="split-media reveal">
                {{#if feature_image}}<img src="{{img_url feature_image size="l"}}" alt="{{title}}" />{{else}}<div class="split-media-ph" style="background:var(--grad-warm);"><svg width="56" height="56" viewBox="0 0 24 24" fill="none"><path d="M3 12h4l2-5 4 10 2-5h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></div>{{/if}}
            </div>
            <div class="split-body reveal reveal-delay-1">
                <span class="eyebrow">About the Programme</span>
                <h2 class="prog-about-h">A healthy, safe society for everyone</h2>
                <div class="prog-about-p">
                    <p>{{#if custom_excerpt}}{{custom_excerpt}}{{else}}Arogyam focuses on the health sector by conducting blood donation camps, arranging blood in emergencies, providing ambulance services at free or concessional rates, organising free health check-up camps, and extending financial assistance for medical treatment — building a healthier, safer community since 2008.{{/if}}</p>
                </div>
            </div>
        </div>
    </div>
</section>

{{!-- Our Services --}}
<section class="section bg-soft prog-focus">
    <div class="container">
        <div class="section-head center reveal">
            <span class="eyebrow center">Our Services</span>
            <h2>How we serve health</h2>
        </div>
        <div class="grid grid-4">
            {{#get "posts" filter="tag:arogyam-activities" limit="100" order="published_at asc" as |acts|}}
                {{#if acts}}
                    {{#foreach acts}}
                    <div class="feature-card reveal">
                        <span class="feature-icon">{{#if feature_image}}<img src="{{img_url feature_image size="xs"}}" alt="{{title}}" style="width:100%;height:100%;object-fit:cover;border-radius:14px;" />{{else}}<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5L20 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>{{/if}}</span>
                        <h3>{{title}}</h3>
                        <p>{{excerpt words="20"}}</p>
                    </div>
                    {{/foreach}}
                {{else}}
                    <div class="feature-card reveal"><span class="feature-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="7" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M17 10h3l2 3v4h-5M7 11v2M6 12h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span><h3>24/7 Ambulance</h3><p>Free and concessional ambulance services across rural Belthangady taluk.</p></div>
                    <div class="feature-card reveal reveal-delay-1"><span class="feature-icon blue"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 21s-7-4.35-9.5-9C1 9 2.5 5 6 5c2 0 3.2 1.2 4 2.5C10.8 6.2 12 5 14 5c3.5 0 5 4 3.5 7C19 16.65 12 21 12 21z" stroke="currentColor" stroke-width="1.6"/></svg></span><h3>Blood Donation Drives</h3><p>Camps with clubs and associations to reduce blood scarcity and arrange blood in emergencies.</p></div>
                    <div class="feature-card reveal reveal-delay-2"><span class="feature-icon teal"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M9 12h6M12 9v6M4 7h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V7zM8 7V5a2 2 0 012-2h4a2 2 0 012 2v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span><h3>Health Awareness Camps</h3><p>Regular health awareness and check-up camps conducted in rural places.</p></div>
                    <div class="feature-card reveal reveal-delay-3"><span class="feature-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M19 9a7 7 0 11-14 0 7 7 0 0114 0zM12 12v6M9 21h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span><h3>Medical Camps</h3><p>Free medical check-up camps organised for the wellbeing of rural communities.</p></div>
                {{/if}}
            {{/get}}
        </div>
    </div>
</section>

{{!-- Extra editable content (page body line 3 onwards) — full-width box, hidden until filled --}}
<section class="section prog-extra" hidden>
    <div class="container">
        <div class="prog-extra-box"><div class="prog-extra-body post-content"></div></div>
    </div>
</section>

{{!-- Apply band (label/description/link editable via Meta Title, Description, Canonical URL) --}}
<section class="section-sm pp-tight">
    <div class="container">
        <div class="apply-band reveal">
            <div class="apply-band-text">
                <h2>{{#if meta_title}}{{meta_title}}{{else}}Apply for Arogyam{{/if}}</h2>
                <p>{{#if meta_description}}{{meta_description}}{{else}}Request health services, an ambulance, or partner with us to organise a health camp or blood donation drive in your community.{{/if}}</p>
            </div>
            <div class="apply-band-actions">
                <a href="{{#if canonical_url}}{{canonical_url}}{{else}}{{@custom.donate_external_url}}{{/if}}" target="_blank" rel="noopener" class="btn btn-primary btn-lg">Apply Now <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H8M17 7v9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
                <a href="/contact/" class="btn btn-outline btn-lg">Contact Us</a>
            </div>
        </div>
    </div>
</section>

<section class="section pp-tight">
    <div class="container">
        <div class="section-head center reveal"><span class="eyebrow center">Arogyam Impact</span><h2>Health, delivered</h2></div>
        <div class="impact-grid-wrap reveal" style="max-width:960px;margin:0 auto;">
            <div class="impact-icons-grid ig-4">
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/ambulance.png"}}" alt="Ambulance" loading="lazy"></span><span class="num" data-target="600">600+</span><span class="lbl">Ambulance Service Calls</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/medical-camp.png"}}" alt="Health camps" loading="lazy"></span><span class="num" data-target="300">300</span><span class="lbl">Health Awareness Camps</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/blood-units.png"}}" alt="Blood collected" loading="lazy"></span><span class="num" data-target="11,399">11,399</span><span class="lbl">Units of Blood Collected</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/serving-health.png"}}" alt="Health services" loading="lazy"></span><span class="num" data-target="13,500+">13,500+</span><span class="lbl">Health Services Delivered</span></div>
            </div>
        </div>
    </div>
</section>

{{!-- Success stories --}}
{{#get "posts" filter="tag:arogyam-stories" limit="3" order="published_at desc" as |stories|}}
    {{#if stories}}
    <section class="section bg-soft">
        <div class="container">
            <div class="section-head center reveal prog-mini"><span class="eyebrow center">Success Stories</span><h2>Healthier lives, stronger communities</h2></div>
            <div class="grid grid-3">
                {{#foreach stories}}
                <a href="{{url}}" class="story-card reveal"><div class="story-card-bg">{{#if feature_image}}<img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy" />{{else}}<div class="story-card-ph"></div>{{/if}}</div><div class="story-card-body"><span class="pill">Success Story</span><h3>{{title}}</h3><p>{{excerpt words="22"}}</p><span class="story-card-more">Read story <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span></div></a>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- Testimonials (program-specific) --}}
{{#get "posts" filter="tag:arogyam-testimonials" limit="3" order="published_at desc" as |quotes|}}
    {{#if quotes}}
    <section class="section bg-muted">
        <div class="container">
            <div class="section-head center reveal prog-mini"><span class="eyebrow center">In Their Words</span><h2>What patients say</h2></div>
            <div class="grid grid-3">
                {{#foreach quotes}}
                <div class="tcard reveal"><span class="tcard-qicon"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M7 7h4v6c0 2.2-1.4 3.6-3.6 4l-.4-1.5C8.3 15 9 14.3 9 13H7V7zm7 0h4v6c0 2.2-1.4 3.6-3.6 4l-.4-1.5c1.3-.5 2-1.2 2-2.5h-2V7z"/></svg></span><p>{{excerpt words="38"}}</p><div class="tcard-author">{{#if feature_image}}<img src="{{img_url feature_image size="xs"}}" alt="{{title}}" />{{else}}<span class="ta-ph"><svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3.4" stroke="currentColor" stroke-width="1.7"/><path d="M5 20c0-3.3 3.1-5.5 7-5.5s7 2.2 7 5.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg></span>{{/if}}<div><b>{{title}}</b><span>Beneficiary</span></div></div></div>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- Album --}}
{{#get "posts" filter="tag:arogyam-album" limit="8" order="published_at desc" as |album|}}
    {{#if album}}
    <section class="section">
        <div class="container">
            <div class="section-head center reveal"><span class="eyebrow center">Gallery</span><h2>Moments from Arogyam</h2></div>
            <div class="album-grid reveal">
                {{#foreach album}}
                <div class="album-item{{#if @first}} wide{{/if}}">{{#if feature_image}}<img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy" />{{else}}<div class="album-ph a{{@number}}"><svg width="32" height="32" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><circle cx="9" cy="10" r="1.6" stroke="currentColor" stroke-width="1.5"/><path d="M5 18l5-4 4 3 2-2 3 3" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg></div>{{/if}}<span class="album-cap">{{title}}</span></div>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- Video stories (posts tagged arogyam-video) --}}
{{#get "posts" filter="tag:arogyam-video" limit="10" order="published_at asc" as |vids|}}
    {{#if vids}}
    <section class="section pv-section">
        <div class="container">
            <div class="section-head center reveal"><span class="eyebrow center">Watch</span><h2>Stories in motion</h2></div>
            <div class="pv-list">
                {{#foreach vids}}
                <div class="pv-card reveal">
                    <div class="pv-media">
                        {{#if feature_image}}<img src="{{img_url feature_image size="l"}}" alt="{{title}}" loading="lazy" />{{else}}<div class="pv-ph"></div>{{/if}}
                        <button class="pv-play" type="button" aria-label="Play video"><svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></button>
                        <div class="pv-embed"></div>
                    </div>
                    <div class="pv-text">
                        <h3>{{title}}</h3>
                        <div class="pv-desc"></div>
                    </div>
                    <div class="pv-source" hidden>{{content}}</div>
                </div>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- Body gallery (auto-built from a Gallery card in the page body) — home-style bento --}}
<section class="section flush-top prog-gallery" hidden>
    <div class="container">
        <div class="shead-minimal reveal"><span class="shead-label">Gallery</span><h2>Glimpses of our work</h2></div>
        <div class="home-gallery">
            <div class="gallery-source"></div>
            <div class="gallery-rect">
                <button class="g-arrow prev" type="button" aria-label="Previous" hidden><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                <div class="gallery-bento"></div>
                <button class="g-arrow next" type="button" aria-label="Next" hidden><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
            </div>
        </div>
    </div>
</section>

<section class="section cta-banner pp-tight">
    <div class="container">
        <div class="cta-card reveal">
            <h2>Help us keep communities healthy</h2>
            <p>Your support powers ambulances, health camps and blood donation drives across rural Karnataka.</p>
            <div class="cta-actions">
                <a href="/donate/" class="btn btn-light btn-lg">Donate Now</a>
                <a href="/contact/" class="btn btn-ghost-light btn-lg">Contact Us</a>
            </div>
        </div>
    </div>
</section>

{{/post}}
