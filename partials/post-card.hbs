<article class="post-card {{post_class}} reveal">
    <a href="{{url}}" class="post-card-image-link">
        <div class="post-card-image-wrapper">
            {{#if feature_image}}
            <img class="post-card-image"
                 srcset="{{img_url feature_image size="s"}} 300w,
                         {{img_url feature_image size="m"}} 600w,
                         {{img_url feature_image size="l"}} 1000w"
                 sizes="(max-width: 768px) 100vw, 380px"
                 src="{{img_url feature_image size="m"}}"
                 alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                 loading="lazy" />
            {{else}}
            <div class="post-card-ph">
                <svg width="46" height="46" viewBox="0 0 24 24" fill="none"><path d="M12 21s-7-4.35-9.5-9C1 9 2.5 5 6 5c2 0 3.2 1.2 4 2.5C10.8 6.2 12 5 14 5c3.5 0 5 4 3.5 7C19 16.65 12 21 12 21z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
            </div>
            {{/if}}
            {{#if primary_tag}}
            <span class="post-card-primary-tag">{{primary_tag.name}}</span>
            {{/if}}
        </div>
    </a>
    <div class="post-card-content">
        <h3 class="post-card-title"><a href="{{url}}">{{title}}</a></h3>
        <div class="post-card-excerpt">
            <p>{{excerpt words="20"}}</p>
        </div>
        <div class="post-card-meta">
            <a href="{{url}}" class="post-card-more">Read story
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
        </div>
    </div>
</article>
