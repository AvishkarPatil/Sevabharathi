{{!< default}}

{{!-- ============ HERO SLIDER ============ --}}
<section class="hero-slider">
    {{#get "posts" filter="tag:hero-slider" limit="6" order="published_at desc" as |slides|}}
        {{#if slides}}
            {{#foreach slides}}
            <div class="hero-slide{{#if @first}} active{{/if}}">
                <div class="hero-slide-bg{{#unless feature_image}} is-gradient{{/unless}}"{{#if feature_image}} style="background-image:url('{{img_url feature_image size="xl"}}')"{{/if}}></div>
                <div class="hero-slide-inner">
                    <div class="container">
                        <div class="hero-slide-content">
                            <h1>{{title}}</h1>
                            <p>{{excerpt words="33"}}</p>
                            <div class="hero-slide-cta">
                                {{#if og_title}}
                                <a href="{{og_title}}" class="btn btn-primary btn-lg">Learn More
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                </a>
                                <a href="/donate/" class="btn btn-ghost-light btn-lg">Donate</a>
                                {{else}}
                                <a href="/programs/" class="btn btn-primary btn-lg">Our Programs
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                </a>
                                <a href="/donate/" class="btn btn-ghost-light btn-lg">Donate</a>
                                {{/if}}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {{/foreach}}
            <div class="hero-slider-nav">
                {{#foreach slides}}<button class="hero-dot{{#if @first}} active{{/if}}" aria-label="Go to slide {{@number}}"></button>{{/foreach}}
            </div>
        {{else}}
            <div class="hero-slide active">
                <div class="hero-slide-bg{{#unless @site.cover_image}} is-gradient{{/unless}}"{{#if @site.cover_image}} style="background-image:url('{{img_url @site.cover_image size="xl"}}')"{{/if}}></div>
                <div class="hero-slide-inner">
                    <div class="container">
                        <div class="hero-slide-content">
                            <h1>Empowering Lives, Restoring Dignity</h1>
                            <p>Serving 25,000+ lives across Karnataka since 2004 through rehabilitation, women empowerment and community health.</p>
                            <div class="hero-slide-cta">
                                <a href="/programs/" class="btn btn-primary btn-lg">Our Programs
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                </a>
                                <a href="/donate/" class="btn btn-ghost-light btn-lg">Donate</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {{/if}}
    {{/get}}
    <button class="hero-arrow prev" aria-label="Previous slide"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
    <button class="hero-arrow next" aria-label="Next slide"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
</section>

{{!-- ============ ABOUT (collage) ============ --}}
<section class="section about-home">
    <div class="container-wide">
        <div class="about-snapshot-grid">
            <div class="collage reveal">
                <div class="collage-img c1">{{#if @custom.about_image_1}}<img src="{{img_url @custom.about_image_1 size="m"}}" alt="{{@site.title}}" />{{else}}<div class="collage-ph g1"><svg width="40" height="40" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3.5" stroke="currentColor" stroke-width="1.5"/><path d="M5 20c0-3.5 3.1-6 7-6s7 2.5 7 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>{{/if}}</div>
                <div class="collage-img c2">{{#if @custom.about_image_2}}<img src="{{img_url @custom.about_image_2 size="l"}}" alt="{{@site.title}}" />{{else}}<div class="collage-ph g2"><svg width="40" height="40" viewBox="0 0 24 24" fill="none"><path d="M12 21s-7-4.35-9.5-9C1 9 2.5 5 6 5c2 0 3.2 1.2 4 2.5C10.8 6.2 12 5 14 5c3.5 0 5 4 3.5 7C19 16.65 12 21 12 21z" stroke="currentColor" stroke-width="1.5"/></svg></div>{{/if}}</div>
                <div class="collage-img c3">{{#if @custom.about_image_3}}<img src="{{img_url @custom.about_image_3 size="m"}}" alt="{{@site.title}}" />{{else}}<div class="collage-ph g3"><svg width="38" height="38" viewBox="0 0 24 24" fill="none"><path d="M3 12h4l2-5 4 10 2-5h6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg></div>{{/if}}</div>
            </div>
            <div class="about-body reveal reveal-delay-1">
                <span class="eyebrow">Who We Are</span>
                {{#get "posts" filter="tag:home-about" limit="1" as |abt|}}
                    {{#if abt}}
                        {{#foreach abt}}
                        <h2>{{title}}</h2>
                        <div class="about-source" hidden>{{content}}</div>
                        <p class="lead"></p>
                        <div class="about-points"></div>
                        {{/foreach}}
                    {{else}}
                        <h2>A community of care across coastal Karnataka</h2>
                        <p class="lead">{{@site.description}}</p>
                        <div class="about-points">
                            <div class="about-point"><span class="ap-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5L20 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></span><p><b>Rehabilitation</b> for persons with spinal cord injury through Sevadhama residential care.</p></div>
                            <div class="about-point"><span class="ap-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5L20 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></span><p><b>Women empowerment</b> through Sabalini skill development and tailoring camps since 2006.</p></div>
                            <div class="about-point"><span class="ap-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5L20 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></span><p><b>Community health</b> through Arogyam camps, blood drives and ambulance services since 2008.</p></div>
                        </div>
                    {{/if}}
                {{/get}}
                <a href="/about/" class="btn btn-outline" style="margin-top:28px;">Learn more about us
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
            </div>
        </div>
    </div>
</section>

{{!-- ============ FOCUS AREAS ============ --}}
<section class="section bg-soft">
    <div class="container">
        <div class="shead-minimal reveal">
            <span class="shead-label">What We Focus On</span>
            <h2>Three challenges, one mission</h2>
        </div>
        <div class="focus-grid">
            {{#get "posts" filter="tag:home-focus" limit="3" order="published_at asc" as |focus|}}
                {{#if focus}}
                    {{#foreach focus}}
                    <a href="{{#if canonical_url}}{{canonical_url}}{{else}}{{url}}{{/if}}" class="focus-card c{{@number}} reveal">
                        <div class="focus-card-bg"{{#if feature_image}} style="background-image:url('{{img_url feature_image size="m"}}')"{{/if}}></div>
                        <span class="focus-num">0{{@number}}</span>
                        {{#if meta_title}}<span class="pill">{{meta_title}}</span>{{/if}}
                        <h3>{{title}}</h3>
                        <p>{{excerpt words="30"}}</p>
                        <span class="focus-link">{{#if meta_description}}{{meta_description}}{{else}}Read More{{/if}} <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                    </a>
                    {{/foreach}}
                {{else}}
                    <a href="/sevadhama/" class="focus-card c1 reveal"><div class="focus-card-bg"></div><span class="focus-num">01</span><span class="pill">Disability</span><h3>Disability &amp; Rehabilitation</h3><p>Karnataka has over 13 lakh persons with disabilities. We bring bedridden spinal cord injury survivors back to dignity and independence.</p><span class="focus-link">Explore Sevadhama <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span></a>
                    <a href="/sabalini/" class="focus-card c2 reveal reveal-delay-1"><div class="focus-card-bg"></div><span class="focus-num">02</span><span class="pill">Women</span><h3>Women Empowerment</h3><p>Rural women reinvest up to 90% of their income into their families. We equip them with skills to work their way out of poverty.</p><span class="focus-link">Explore Sabalini <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span></a>
                    <a href="/arogyam/" class="focus-card c3 reveal reveal-delay-2"><div class="focus-card-bg"></div><span class="focus-num">03</span><span class="pill">Health</span><h3>Community Health</h3><p>We bring free health camps, blood donation drives and 24/7 ambulance services to rural communities that need them the most.</p><span class="focus-link">Explore Arogyam <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span></a>
                {{/if}}
            {{/get}}
        </div>
    </div>
</section>

{{!-- ============ PROGRAMS (3 equal cards) ============ --}}
<section class="section">
    <div class="container">
        <div class="shead-split reveal">
            <div class="sh-left">
                <span class="eyebrow">Our Programs</span>
                <h2>Three pillars of lasting change</h2>
            </div>
            <div class="sh-right">
                <p>Focused initiatives that restore dignity, build skills, and protect the health of those who need it most.</p>
                <a href="/programs/" class="btn-link">All programmes <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            </div>
        </div>
        <div class="programs-row">
            {{#get "pages" filter="tag:home-programs" limit="3" order="published_at asc" as |programs|}}
                {{#if programs}}
                    {{#foreach programs}}
                    <a href="{{#if og_title}}{{og_title}}{{else}}{{url}}{{/if}}" class="pg c{{@number}} reveal{{#if @last}} reveal-delay-2{{else}}{{#unless @first}} reveal-delay-1{{/unless}}{{/if}}">
                        <div class="pg-bg">{{#if feature_image}}<img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy" />{{else}}<div class="pg-bg-ph"></div>{{/if}}</div>
                        <div class="pg-panel">
                            <h3 class="pg-title">{{title}} <span class="pg-arrow"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H8M17 7v9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span></h3>
                            <p class="pg-desc">{{excerpt words="22"}}</p>
                        </div>
                    </a>
                    {{/foreach}}
                {{else}}
                    <a href="/sevadhama/" class="pg c1 reveal"><div class="pg-bg"><div class="pg-bg-ph"></div></div><div class="pg-panel"><h3 class="pg-title">Sevadhama <span class="pg-arrow"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H8M17 7v9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span></h3><p class="pg-desc">Residential 12-week rehabilitation for persons with spinal cord injury — therapy, life skills, wheelchair training and livelihood support.</p></div></a>
                    <a href="/sabalini/" class="pg c2 reveal reveal-delay-1"><div class="pg-bg"><div class="pg-bg-ph"></div></div><div class="pg-panel"><h3 class="pg-title">Sabalini <span class="pg-arrow"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H8M17 7v9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span></h3><p class="pg-desc">Rural women empowerment through free tailoring camps, skill development and self-employment support since 2006.</p></div></a>
                    <a href="/arogyam/" class="pg c3 reveal reveal-delay-2"><div class="pg-bg"><div class="pg-bg-ph"></div></div><div class="pg-panel"><h3 class="pg-title">Arogyam <span class="pg-arrow"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H8M17 7v9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span></h3><p class="pg-desc">Community health camps, blood donation drives and 24/7 affordable ambulance services since 2008.</p></div></a>
                {{/if}}
            {{/get}}
        </div>
    </div>
</section>

{{!-- ============ SOCIAL IMPACT (glassy cards) ============ --}}
<section class="section flush-top">
    <div class="container">
        <div class="shead-minimal reveal">
            <span class="shead-label">Social Impact</span>
            <h2>The difference we've made<span class="dot">.</span></h2>
            <p class="shead-sub nowrap-desktop">Two decades of measurable change across seven districts of Karnataka.</p>
        </div>
        <div class="impact-hl-grid reveal">
            <div class="imp-hl">
                <span class="imp-hl-ic"><img src="{{asset "impact-icons/rehabilitation.png"}}" alt="Rehabilitation" loading="lazy"></span>
                <div class="imp-hl-figs">
                    <div class="fig"><span class="n" data-target="{{@custom.home_stat_identified}}">{{@custom.home_stat_identified}}</span><span class="l">Identified</span></div>
                    <div class="fig"><span class="n" data-target="{{@custom.home_stat_rehabilitated}}">{{@custom.home_stat_rehabilitated}}</span><span class="l">Rehabilitated</span></div>
                </div>
                <h3 class="imp-hl-title">Restoring lives through rehabilitation</h3>
            </div>
            <div class="imp-hl">
                <span class="imp-hl-ic"><img src="{{asset "impact-icons/wheelchair.png"}}" alt="Mobility devices" loading="lazy"></span>
                <div class="imp-hl-figs"><div class="fig"><span class="n" data-target="{{@custom.home_stat_devices}}">{{@custom.home_stat_devices}}</span><span class="l">Devices</span></div></div>
                <h3 class="imp-hl-title">Enabling independence &amp; accessible living</h3>
            </div>
            <div class="imp-hl">
                <span class="imp-hl-ic"><img src="{{asset "impact-icons/women-empowered.png"}}" alt="Families empowered" loading="lazy"></span>
                <div class="imp-hl-figs"><div class="fig"><span class="n" data-target="{{@custom.home_stat_families}}">{{@custom.home_stat_families}}</span><span class="l">Families</span></div></div>
                <h3 class="imp-hl-title">Sustainable livelihoods &amp; women empowerment</h3>
            </div>
            <div class="imp-hl">
                <span class="imp-hl-ic"><img src="{{asset "impact-icons/serving-health.png"}}" alt="Community health" loading="lazy"></span>
                <div class="imp-hl-figs"><div class="fig"><span class="n" data-target="{{@custom.home_stat_health}}">{{@custom.home_stat_health}}</span><span class="l">Health services</span></div></div>
                <h3 class="imp-hl-title">Community health across Karnataka</h3>
                <span class="imp-hl-sub">7 Districts &middot; 48 Taluks</span>
            </div>
            <div class="imp-hl">
                <span class="imp-hl-ic"><img src="{{asset "impact-icons/blood-units.png"}}" alt="Blood collected" loading="lazy"></span>
                <div class="imp-hl-figs"><div class="fig"><span class="n" data-target="{{@custom.home_stat_blood}}">{{@custom.home_stat_blood}}</span><span class="l">Blood units</span></div></div>
                <h3 class="imp-hl-title">Strengthening the blood-donation network</h3>
            </div>
        </div>
        <div style="text-align:center; margin-top:44px;" class="reveal"><a href="/impact/" class="btn btn-outline btn-lg">See our full impact <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a></div>
    </div>
</section>

{{!-- ============ SUCCESS STORIES (slider) ============ --}}
{{#get "posts" filter="tag:success-stories" limit="12" order="published_at desc" as |stories|}}
    {{#if stories}}
    <section class="section flush-top">
        <div class="container">
            <div class="shead-split reveal">
                <div class="sh-left"><span class="eyebrow">Success Stories</span><h2>From bedridden to self-reliant</h2></div>
                <div class="sh-right story-nav">
                    <button class="sn-btn sn-prev" type="button" aria-label="Previous"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                    <button class="sn-btn sn-next" type="button" aria-label="Next"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                </div>
            </div>
            <div class="story-slider" id="story-slider">
                <div class="story-track">
                    {{#foreach stories}}
                    <div class="story-card reveal">
                        <div class="story-card-bg">{{#if feature_image}}<img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy" />{{else}}<div class="story-card-ph"></div>{{/if}}</div>
                        <a href="{{url}}" class="story-card-cover" aria-label="{{title}}"></a>
                        <button class="story-play" type="button" data-video-trigger aria-label="Play video" hidden><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></button>
                        <div class="story-video-src" hidden>{{content}}</div>
                        <div class="story-card-body">{{#primary_tag}}<span class="pill">{{name}}</span>{{/primary_tag}}<h3>{{title}}</h3><p>{{excerpt words="22"}}</p><a href="{{url}}" class="story-card-more">Read story <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a></div>
                    </div>
                    {{/foreach}}
                </div>
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- ============ TESTIMONIALS (expanding slider) ============ --}}
{{#get "posts" filter="tag:home-testimonials" limit="3" order="published_at desc" as |quotes|}}
    {{#if quotes}}
    <section class="section flush-top">
        <div class="container">
            <div class="t-head reveal">
                <h2 class="t-title">And this is the <span class="hl">difference</span> it makes</h2>
                <p class="t-sub">because when a life is restored, an entire family rises with it.</p>
            </div>
            <div class="tslider reveal" id="tslider">
                {{#foreach quotes}}
                <article class="tslide{{#if @first}} active{{/if}}">
                    <div class="tslide-img">{{#if feature_image}}<img src="{{img_url feature_image size="l"}}" alt="{{title}}" loading="lazy" />{{else}}<div class="tslide-ph"></div>{{/if}}</div>
                    <div class="tslide-overlay"></div>
                    <div class="tslide-content">
                        <svg class="tslide-qicon" width="40" height="40" viewBox="0 0 24 24" fill="currentColor"><path d="M7 7h4v6c0 2.2-1.4 3.6-3.6 4l-.4-1.5C8.3 15 9 14.3 9 13H7V7zm7 0h4v6c0 2.2-1.4 3.6-3.6 4l-.4-1.5c1.3-.5 2-1.2 2-2.5h-2V7z"/></svg>
                        <p class="tslide-quote">{{excerpt words="34"}}</p>
                        <div class="tslide-name">{{title}}</div>
                        {{#primary_tag}}<div class="tslide-org">{{name}}</div>{{/primary_tag}}
                        <div class="tslide-source" hidden>{{content}}</div>
                    </div>
                </article>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- ============ SUPPORTERS LOGO SLIDER ============ --}}
{{#get "posts" filter="tag:home-partners" limit="1" as |sp|}}
    {{#if sp}}
    <section class="section-sm supporters flush-top">
        <div class="container">
            <div class="shead-divider reveal"><span class="dv">Our Supporters</span></div>
            <p class="shead-sub reveal">Backed by people and organisations who believe in the cause.</p>
        </div>
        <div class="supporters-source">{{#foreach sp}}{{content}}{{/foreach}}</div>
        <div class="container">
            <div class="logo-slider reveal">
                <div class="ls-edge left"></div>
                <div class="ls-edge right"></div>
                <button class="ls-arrow prev" aria-label="Previous"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                <button class="ls-arrow next" aria-label="Next"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                <div class="ls-viewport"><div class="ls-track" id="supporters-track"></div></div>
                <div class="ls-viewport"><div class="ls-track" id="supporters-track-2"></div></div>
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- ============ UPCOMING EVENTS ============ --}}
{{#get "posts" filter="tag:event" limit="12" order="published_at asc" as |events|}}
    {{#if events}}
    <section class="section home-events" id="home-events" hidden>
        <div class="container">
            <div class="shead-split reveal">
                <div class="sh-left"><span class="eyebrow">What's Next</span><h2>Upcoming events &amp; camps</h2></div>
                <div class="sh-right"><a href="/events/" class="btn-link">All events <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a></div>
            </div>
            <div class="he-grid" id="he-grid">
                {{#foreach events}}
                <a href="{{url}}" class="he-card reveal" data-date="{{custom_excerpt}}">
                    <div class="he-media">{{#if feature_image}}<img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy" />{{else}}<div class="he-ph"></div>{{/if}}
                        <span class="he-date"></span>
                    </div>
                    <div class="he-body"><h3>{{title}}</h3></div>
                </a>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- ============ IMAGE GALLERY ============ --}}
{{#get "posts" filter="tag:home-gallery" limit="1" as |gal|}}
    {{#if gal}}
    <section class="section flush-top">
        <div class="container">
            <div class="shead-minimal reveal"><span class="shead-label">Gallery</span><h2>Glimpses of our work</h2></div>
            <div class="home-gallery reveal">
                <div class="gallery-source">{{#foreach gal}}{{content}}{{/foreach}}</div>
                <div class="gallery-rect">
