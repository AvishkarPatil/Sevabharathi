{{!< default}}

<header class="tag-header">
    <div class="container">
        <span class="pill">Newsletters</span>
        <h1>Our newsletters</h1>
        <p>Monthly updates from the field — stories, camps and progress. Open any issue to read it.</p>
    </div>
</header>

<section class="section">
    <div class="container">
        {{#get "posts" filter="tag:newsletter" limit="100" order="published_at desc" as |items|}}
            {{#if items}}
            <div class="nl-toolbar reveal">
                <div class="nl-filter">
                    <label for="nl-year">Filter by year</label>
                    <div class="filter-select"><select id="nl-year"><option value="all">All years</option></select></div>
                </div>
                <button type="button" class="btn btn-subscribe" data-nl-open>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.7"/><path d="M4 7l8 6 8-6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    Subscribe to newsletter
                </button>
            </div>
            <div class="nl-grid" id="nl-grid">
                {{#foreach items}}
                <div class="nl-card" data-url="{{url}}" data-year="{{date published_at format="YYYY"}}" role="button" tabindex="0" aria-label="Open {{title}}">
                    <div class="nl-cover">
                        {{#if feature_image}}<img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy" />{{else}}<div class="nl-cover-ph"><svg width="46" height="46" viewBox="0 0 24 24" fill="none"><path d="M14 3H7a2 2 0 00-2 2v14a2 2 0 002 2h10a2 2 0 002-2V8l-5-5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M14 3v5h5M9 13h6M9 17h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></div>{{/if}}
                    </div>
                    <div class="nl-title">{{title}}
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                    <div class="nl-source">{{content}}</div>
                </div>
                {{/foreach}}
            </div>
            <p class="empty-note nl-empty" id="nl-empty" hidden>No newsletters for this year.</p>
            {{else}}
            <p class="empty-note">No newsletters published yet. Add posts tagged <strong>newsletter</strong> (PDF as a File card in the body — the card shows the first page automatically).</p>
            {{/if}}
        {{/get}}
    </div>
</section>
