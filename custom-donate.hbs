{{!< default}}
{{#post}}

<header class="page-hero center">
    <div class="container">
        <div class="page-hero-inner reveal">
            <nav class="breadcrumb"><a href="{{@site.url}}">Home</a> <span>/</span> <span>{{title}}</span></nav>
            <span class="eyebrow center">Support Our Mission</span>
            <h1>{{title}}</h1>
            {{#if custom_excerpt}}<p>{{custom_excerpt}}</p>{{else}}<p>Your contribution helps a survivor stand again, a woman earn with dignity, and a village stay healthy.</p>{{/if}}
        </div>
    </div>
</header>

<section class="section">
    <div class="container">
        <div class="donate-grid">
            {{!-- Bank details come from the PAGE BODY content --}}
            <div class="bank-detail-card reveal">
                <span class="eyebrow">Bank Transfer</span>
                <h2 style="font-size:1.4rem; margin:6px 0 18px;">Account details</h2>
                <div class="post-content donate-bank-content">{{content}}</div>

                <div class="tax-note" style="margin-top:26px;">
                    <span class="tn-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                    <p>Contributions to our Trust are eligible for tax benefits under Section 80G of the Income Tax Act.</p>
                </div>
            </div>

            {{!-- QR uses the PAGE FEATURE IMAGE --}}
            <div class="qr-card reveal reveal-delay-1">
                <span class="eyebrow center">Scan &amp; Pay</span>
                <h2 style="font-size:1.5rem; margin:6px 0 20px;">Quick UPI donation</h2>
                {{#if feature_image}}
                    <img src="{{img_url feature_image size="m"}}" alt="Donation QR code" />
                {{else}}
                    <div class="qr-ph"><svg width="48" height="48" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.6"/><rect x="14" y="3" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.6"/><rect x="3" y="14" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.6"/><path d="M14 14h3v3M21 14v7h-7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></div>
                {{/if}}
                {{#if @custom.donate_upi_id}}<p style="font-weight:600; color:var(--color-dark);">UPI: {{@custom.donate_upi_id}}</p>{{/if}}
                {{#if @custom.donate_external_url}}
                <a href="{{@custom.donate_external_url}}" target="_blank" rel="noopener" class="btn btn-primary btn-lg" style="margin-top:20px; width:100%;">Donate Online
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H8M17 7v9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                {{/if}}
            </div>
        </div>
    </div>
</section>

{{!-- Support Sevadhama — intro (from page Excerpt) + points + sponsorship table --}}
<section class="section">
    <div class="container">
        <div class="section-head center reveal dn-head"><span class="eyebrow center">Support Sevadhama</span><h2>Transform lives through your generosity</h2></div>
        <div class="ds-wrap reveal">
            <p class="ds-intro">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}Sevadhama, a non-profit rehabilitation facility, depends on charitable donations to continue empowering people with spinal cord injuries to achieve their fullest potential. Contributions to our Trust are eligible for tax benefits under Section 80G. Your gift can directly impact rehabilitation activities or specific needs you choose to support. At Sevadhama, we collect only a nominal fee from beneficiaries for the interventions they undergo, while donations cover the rest of the therapy and essential services.{{/if}}</p>

            <h3 class="ds-sub">Why your support matters</h3>
            <ul class="ds-points">
                <li><strong>Assistive Devices:</strong> Mobility aids and appliances can completely transform the life of a child or youth with disability.</li>
                <li><strong>Sustaining Excellence:</strong> Your donation helps us maintain high-quality care and expand our services to reach more individuals in need.</li>
            </ul>

            <p class="ds-note">Join us in this noble mission and help restore independence, dignity, and hope to those living with spinal cord injuries.</p>

            <table class="ds-table">
                <tbody>
                    <tr><td>Sponsor a medical kit to SCI for one month</td><td>₹2,000</td></tr>
                    <tr><td>Sponsor a caretaker for a SCI patient for one month</td><td>₹3,000</td></tr>
                    <tr><td>Sponsor one-time food at Sevadhama</td><td>₹3,000</td></tr>
                    <tr><td>Sponsor an assistive device (walker, caliper)</td><td>₹10,000</td></tr>
                    <tr><td>Sponsor a field visit of SCI inmates</td><td>₹10,000</td></tr>
                    <tr><td>Celebrate your birthday at Sevadhama by donating for one day's food</td><td>₹10,000</td></tr>
                    <tr><td>Sponsor a wheelchair for a SCI</td><td>₹16,000</td></tr>
                    <tr><td>Sponsor a nominal fee of a SCI for one month</td><td>₹21,000</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</section>

{{!-- What your donation funds --}}
<section class="section bg-soft">
    <div class="container">
        <div class="section-head center reveal dn-head"><span class="eyebrow center">Your Impact</span><h2>What your donation funds</h2></div>
        <div class="grid grid-3">
            <div class="feature-card reveal"><span class="donate-ic ic-a"><img src="{{asset "donate/rehabilitation.png"}}" alt="Rehabilitation" loading="lazy" /></span><h3>Rehabilitation</h3><p>Funds wheelchairs, calipers, therapy and a 12-week residential programme for spinal cord injury survivors.</p></div>
            <div class="feature-card reveal reveal-delay-1"><span class="donate-ic ic-b"><img src="{{asset "donate/women-livelihoods.png"}}" alt="Women's Livelihoods" loading="lazy" /></span><h3>Women's Livelihoods</h3><p>Supports free tailoring camps and skill development that help rural women earn with dignity.</p></div>
            <div class="feature-card reveal reveal-delay-2"><span class="donate-ic ic-c"><img src="{{asset "donate/community-health.png"}}" alt="Community Health" loading="lazy" /></span><h3>Community Health</h3><p>Powers health camps, blood donation drives and 24/7 ambulance services for rural communities.</p></div>
        </div>
    </div>
</section>

{{/post}}
