{{!< default}}
{{#post}}

<header class="page-hero center">
    <div class="container">
        <div class="page-hero-inner reveal">
            <nav class="breadcrumb"><a href="{{@site.url}}">Home</a> <span>/</span> <span>{{title}}</span></nav>
            <h1>{{title}}</h1>
            {{#if custom_excerpt}}<p>{{custom_excerpt}}</p>{{else}}<p>Fully registered and compliant — established 2004, registered under the Indian Trust Act in 2012.</p>{{/if}}
        </div>
    </div>
</header>

