<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{meta_title}}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Sora:wght@500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" type="text/css" href="{{asset "css/screen.css"}}" />

    {{ghost_head}}
</head>
<body class="{{body_class}}"{{#if @member}} data-member="1"{{/if}}>

    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
        <div class="nav-capsule">
            <div class="nav-logo">
                <a href="{{@site.url}}" aria-label="{{@site.title}}">
                    {{#if @site.logo}}<img src="{{@site.logo}}" alt="{{@site.title}}" />{{else}}<span class="nav-logo-text">{{@site.title}}</span>{{/if}}
                </a>
            </div>

            <nav class="nav-menu nav-build" aria-label="Primary">
                {{navigation}}
            </nav>

            <div class="nav-actions">
                <a href="/donate/" class="btn btn-primary btn-donate-desktop">
                    Donate
                    <svg width="17" height="17" viewBox="0 0 122.88 102.36" fill="currentColor" aria-hidden="true"><path d="M29.83,89.55V52.63h16.61c7.04,1.26,14.08,5.08,21.12,9.51h12.9c5.84,0.35,8.9,6.27,3.22,10.16c-4.52,3.32-10.49,3.13-16.61,2.58c-4.22-0.21-4.4,5.46,0,5.48c1.53,0.12,3.19-0.24,4.64-0.24c7.64-0.01,13.92-1.47,17.77-7.5l1.93-4.51l19.19-9.51c9.6-3.16,16.42,6.88,9.35,13.87c-13.9,10.11-28.15,18.43-42.73,25.15c-10.59,6.44-21.18,6.22-31.76,0L29.83,89.55L29.83,89.55z M76.08,7.8c3.63-3.79,6.17-7.06,11.77-7.7c10.5-1.21,20.16,9.55,14.86,20.14c-1.51,3.02-4.58,6.6-7.98,10.12c-3.73,3.86-7.86,7.65-10.76,10.52l-7.89,7.83l-6.52-6.28c-7.84-7.55-20.63-17.06-21.05-28.84c-0.3-8.25,6.22-13.54,13.7-13.44C68.91,0.23,71.72,3.56,76.08,7.8L76.08,7.8L76.08,7.8z M0,49.08h24.83v44.18H0V49.08L0,49.08z"/></svg>
                </a>
                <button class="menu-toggle" aria-label="Open menu" aria-expanded="false">
                    <span></span><span></span><span></span>
                </button>
            </div>
        </div>
    </header>

    <!-- Mobile drawer -->
    <div class="mobile-drawer" aria-hidden="true">
        <div class="mobile-drawer-inner">
            <button class="mobile-close" aria-label="Close menu">&times;</button>
            <nav class="mobile-nav nav-build" aria-label="Mobile">
                {{navigation}}
            </nav>
            <a href="/donate/" class="btn btn-primary btn-lg">Donate Now</a>
        </div>
    </div>

    <main id="main" class="site-main {{#is "home"}}is-home{{else}}is-page{{/is}}">
        {{{body}}}
    </main>

    {{> "footer"}}

    {{!-- Newsletter subscribe popup (Ghost members) --}}
    <div class="nl-modal" aria-hidden="true">
        <div class="nl-modal-card" role="dialog" aria-modal="true" aria-label="Subscribe to our newsletter">
            <button class="nl-modal-close" aria-label="Close">&times;</button>
            <span class="nl-modal-icon">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.8"/><path d="M4 7l8 6 8-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <h3 class="nl-modal-title">Subscribe to Sevabharti</h3>
            <p class="nl-modal-sub">Monthly stories, camps and progress from the field — straight to your inbox.</p>
            <form class="nl-form" data-members-form="subscribe">
                <div class="nl-field">
                    <input class="nl-input" data-members-email type="email" required placeholder="Enter your email address" aria-label="Email address" />
                    <button type="submit" class="btn btn-subscribe nl-submit">Subscribe</button>
                </div>
                <p class="nl-form-error" data-members-error></p>
                <p class="nl-form-success">Thank you! Please check your inbox to confirm your subscription.</p>
            </form>
            <p class="nl-modal-fine">No spam. Unsubscribe anytime.</p>
        </div>
    </div>

    <!-- Language selector (Google Translate) -->
    <div class="lang-fab notranslate" translate="no">
        <div class="lang-menu" role="menu">
            <button data-lang="en" role="menuitem">English</button>
            <button data-lang="kn" role="menuitem">ಕನ್ನಡ</button>
            <button data-lang="hi" role="menuitem">हिन्दी</button>
        </div>
        <button class="lang-fab-btn" aria-label="Choose language">
            <svg width="24" height="24" viewBox="0 0 512 512" fill="currentColor" aria-hidden="true"><path d="M478.33,433.6l-90-218a22,22,0,0,0-40.67,0l-90,218a22,22,0,1,0,40.67,16.79L316.66,406H419.33l18.33,44.39A22,22,0,0,0,458,464a22,22,0,0,0,20.32-30.4ZM334.83,362,368,281.65,401.17,362Z"/><path d="M267.84,342.92a22,22,0,0,0-4.89-30.7c-.2-.15-15-11.13-36.49-34.73,39.65-53.68,62.11-114.75,71.27-143.49H330a22,22,0,0,0,0-44H214V70a22,22,0,0,0-44,0V90H54a22,22,0,0,0,0,44H251.25c-9.52,26.95-27.05,69.5-53.79,108.36-31.41-41.68-43.08-68.65-43.17-68.87a22,22,0,0,0-40.58,17c.58,1.38,14.55,34.23,52.86,83.93.92,1.19,1.83,2.35,2.74,3.51-39.24,44.35-77.74,71.86-93.85,80.74a22,22,0,1,0,21.07,38.63c2.16-1.18,48.6-26.89,101.63-85.59,22.52,24.08,38,35.44,38.93,36.1a22,22,0,0,0,30.75-4.9Z"/></svg>
        </button>
    </div>

    <div id="google_translate_element"></div>
    <script type="text/javascript">
        function googleTranslateElementInit() {
            new google.translate.TranslateElement({
                pageLanguage: 'en',
                includedLanguages: 'kn,hi,en',
                layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
                autoDisplay: false
            }, 'google_translate_element');
        }
    </script>
    <script src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit" defer></script>

    <script src="{{asset "js/main.js"}}" defer></script>
    {{ghost_foot}}
</body>
</html>
