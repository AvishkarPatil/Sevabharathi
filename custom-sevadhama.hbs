{{!< default}}
{{#post}}

<div class="prog-source" hidden>{{content}}</div>

{{!-- Hero --}}
<header class="page-hero center">
    <div class="container">
        <div class="page-hero-inner reveal">
            <nav class="breadcrumb"><a href="{{@site.url}}">Home</a> <span>/</span> <a href="/programs/">Programs</a> <span>/</span> <span>{{title}}</span></nav>
            <span class="eyebrow center">Rehabilitation Programme</span>
            <h1>{{title}}</h1>
            <p>{{#if custom_excerpt}}{{custom_excerpt}}{{else}}Residential rehabilitation for spinal cord injury survivors at Southadka.{{/if}}</p>
        </div>
    </div>
</header>

{{!-- Feature image band --}}
{{#if feature_image}}
<div class="container" style="margin-top:-26px; position:relative; z-index:2;">
    <div class="activity-detail-img reveal"><img src="{{img_url feature_image size="xl"}}" alt="{{title}}" /></div>
</div>
{{/if}}

{{!-- Description + What is / Focus --}}
<section class="section">
    <div class="container">
        <div class="split">
            <div class="split-body reveal">
                <span class="eyebrow">About the Programme</span>
                <h2 class="prog-about-h">A 12-week journey back to independence</h2>
                <div class="prog-about-p">
                    <p>{{#if custom_excerpt}}{{custom_excerpt}}{{else}}Sevadhama is a residential rehabilitation centre for persons with spinal cord injury, started in 2018 at Southadka, Kokkada. Over a minimum of 12 weeks, residents learn to manage daily routines, transfer from wheelchair to bed, and rebuild the skills needed to live with dignity.{{/if}}</p>
                    <p>Rehabilitation that typically costs ₹2–3 lakhs is offered here for just ₹30,000–40,000, supported by expert physiotherapists, field coordinators and committed staff.</p>
                </div>
            </div>
            <div class="split-media reveal reveal-delay-1">
                <div class="bank-detail-card" style="box-shadow:var(--shadow-card);">
                    <span class="eyebrow">Our Focus</span>
                    <h3 style="margin:6px 0 16px;">How we help</h3>
                    <ul class="check-list">
                        <li><span class="ci"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5L20 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span>Maximise physical function &amp; prevent secondary complications</li>
                        <li><span class="ci"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5L20 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span>Manage bladder, bowel &amp; pressure-sore care</li>
                        <li><span class="ci"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5L20 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span>Counselling &amp; capacity building</li>
                        <li><span class="ci"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5L20 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span>Sport &amp; cultural activities</li>
                        <li><span class="ci"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5L20 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span>10-bedded residential centre serving 6 districts</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

{{!-- Extra editable content (page body line 3 onwards) — full-width box, hidden until filled --}}
<section class="section prog-extra" hidden>
    <div class="container">
        <div class="prog-extra-box"><div class="prog-extra-body post-content"></div></div>
    </div>
</section>

{{!-- Apply band (label/description/link editable via Meta Title, Description, Canonical URL) --}}
<section class="section-sm pp-tight">
    <div class="container">
        <div class="apply-band reveal">
            <div class="apply-band-text">
                <h2>{{#if meta_title}}{{meta_title}}{{else}}Enquire for Sevadhama{{/if}}</h2>
                <p>{{#if meta_description}}{{meta_description}}{{else}}Reach out to procure rehabilitation services and facilities for a better, more independent future. We extend unconditional support to help survivors lead a life of dignity and self-reliance.{{/if}}</p>
            </div>
            <div class="apply-band-actions">
                <a href="{{#if canonical_url}}{{canonical_url}}{{else}}{{@custom.donate_external_url}}{{/if}}" target="_blank" rel="noopener" class="btn btn-primary btn-lg">Enquire Now <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H8M17 7v9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
                <a href="/contact/" class="btn btn-outline btn-lg">Contact Us</a>
            </div>
        </div>
    </div>
</section>

{{!-- Activities --}}
<section class="section bg-soft prog-focus">
    <div class="container">
        <div class="section-head center reveal"><span class="eyebrow center">What We Do</span><h2>Programme activities</h2></div>
        <div class="grid grid-3">
            {{#get "posts" filter="tag:sevadhama-activities" limit="100" order="published_at asc" as |acts|}}
                {{#if acts}}
                    {{#foreach acts}}
                    <a href="{{url}}" class="feature-card reveal">
                        <span class="feature-icon">{{#if feature_image}}<img src="{{img_url feature_image size="xs"}}" alt="{{title}}" style="width:100%;height:100%;object-fit:cover;border-radius:14px;" />{{else}}<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5L20 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>{{/if}}</span>
                        <h3>{{title}}</h3>
                        <p>{{excerpt words="22"}}</p>
                        <span class="btn-link" style="margin-top:14px;">View activity <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                    </a>
                    {{/foreach}}
                {{else}}
                    <div class="feature-card reveal"><span class="feature-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 20l4-1 9-9-3-3-9 9-1 4zM14 5l3 3" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg></span><h3>Physiotherapy &amp; OT</h3><p>Restorative and compensatory therapy to regain mobility, manage pain and maximise functional independence.</p></div>
                    <div class="feature-card reveal reveal-delay-1"><span class="feature-icon blue"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 3v18M3 7h6M3 12h6M3 17h6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg></span><h3>Life Skills Training</h3><p>ADLs and IADLs — bathing, dressing, cooking, communication, decision-making and interpersonal skills.</p></div>
                    <div class="feature-card reveal reveal-delay-2"><span class="feature-icon teal"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="8" cy="18" r="3" stroke="currentColor" stroke-width="1.6"/><path d="M11 18h5l2-7h-9M8 6h3l2 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span><h3>Wheelchair Skills</h3><p>Basic to advanced training — transfers, ramps, curbs, wheelies — to move safely and confidently.</p></div>
                    <div class="feature-card reveal"><span class="feature-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 4a8 8 0 100 16 8 8 0 000-16zM12 8v4l3 2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></span><h3>Yoga &amp; Pranayama</h3><p>Aerobic fitness, flexibility and wheelchair yoga to build cardiovascular and upper-body strength.</p></div>
                    <div class="feature-card reveal reveal-delay-1"><span class="feature-icon blue"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2a7 7 0 00-4 12.7V17h8v-2.3A7 7 0 0012 2zM9 21h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span><h3>Awareness &amp; Prevention</h3><p>Education on spinal cord injury, emergency response and prevention — the most important line of treatment.</p></div>
                    <div class="feature-card reveal reveal-delay-2"><span class="feature-icon teal"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="9" cy="8" r="3" stroke="currentColor" stroke-width="1.6"/><circle cx="16" cy="9" r="2.4" stroke="currentColor" stroke-width="1.6"/><path d="M3 19c0-3 2.7-5 6-5s6 2 6 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></span><h3>Community Based Rehab</h3><p>Field coordinators provide home therapy, follow-ups and link survivors to government benefits.</p></div>
                {{/if}}
            {{/get}}
        </div>
    </div>
</section>

{{!-- Programme impact --}}
<section class="section pp-tight">
    <div class="container">
        <div class="section-head center reveal"><span class="eyebrow center">Programme Impact</span><h2>Sevadhama by the numbers</h2></div>
        <div class="impact-grid-wrap reveal" style="max-width:960px;margin:0 auto;">
            <div class="sevadhama-impact-source" hidden>{{#get "posts" filter="tag:sevadhama-impact" limit="1" as |rows|}}{{#foreach rows}}{{content}}{{/foreach}}{{/get}}</div>
            <div class="impact-icons-grid ig-4" id="sevadhama-impact-grid" data-iconbase="{{asset "impact-icons/search.png"}}">
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/search.png"}}" alt="Identified" loading="lazy"></span><span class="num" data-target="833">833</span><span class="lbl">Lives Identified</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/rehabilitation.png"}}" alt="Rehabilitated" loading="lazy"></span><span class="num" data-target="279">279</span><span class="lbl">Lives Rehabilitated</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/wheelchair.png"}}" alt="Wheelchairs" loading="lazy"></span><span class="num" data-target="405">405</span><span class="lbl">Wheelchairs Distributed</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/mobility-aids.png"}}" alt="Mobility aids" loading="lazy"></span><span class="num" data-target="797">797</span><span class="lbl">Mobility &amp; Assistive Devices</span></div>
            </div>
        </div>
    </div>
</section>

{{!-- Livelihood --}}
<section class="section bg-soft">
    <div class="container">
        <div class="split reverse">
            <div class="split-media reveal">
                {{#if twitter_image}}<img src="{{img_url twitter_image size="l"}}" alt="{{title}}" loading="lazy" />{{else}}<div class="split-media-ph" style="background:var(--grad-warm);"><svg width="56" height="56" viewBox="0 0 24 24" fill="none"><path d="M3 9l9-5 9 5v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M9 21v-7h6v7" stroke="currentColor" stroke-width="1.4"/></svg></div>{{/if}}
            </div>
            <div class="split-body reveal reveal-delay-1">
                <span class="eyebrow">Beyond Therapy</span>
                <h2>Livelihood &amp; self-employment</h2>
                <p>We help survivors rebuild economic independence — reducing dependence on family, restoring confidence and preventing depression.</p>
                <ul class="check-list">
                    <li><span class="ci"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5L20 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span>Income-generating ideas &amp; marketing support</li>
                    <li><span class="ci"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5L20 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span>Training, follow-up &amp; partial financial assistance</li>
                    <li><span class="ci"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5L20 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span>Material and machinery support</li>
                </ul>
            </div>
        </div>
    </div>
</section>

{{!-- Success stories (program-specific) --}}
{{#get "posts" filter="tag:sevadhama-stories" limit="3" order="published_at desc" as |stories|}}
    {{#if stories}}
    <section class="section">
        <div class="container">
            <div class="section-head center reveal prog-mini"><span class="eyebrow center">Success Stories</span><h2>Lives transformed at Sevadhama</h2></div>
            <div class="grid grid-3">
                {{#foreach stories}}
                <a href="{{url}}" class="story-card reveal">
                    <div class="story-card-bg">{{#if feature_image}}<img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy" />{{else}}<div class="story-card-ph"></div>{{/if}}</div>
                    <div class="story-card-body"><span class="pill">Success Story</span><h3>{{title}}</h3><p>{{excerpt words="22"}}</p><span class="story-card-more">Read story <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span></div>
                </a>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- Testimonials (program-specific) --}}
{{#get "posts" filter="tag:sevadhama-testimonials" limit="3" order="published_at desc" as |quotes|}}
    {{#if quotes}}
    <section class="section bg-muted">
        <div class="container">
            <div class="section-head center reveal prog-mini"><span class="eyebrow center">In Their Words</span><h2>What families say</h2></div>
            <div class="grid grid-3">
                {{#foreach quotes}}
                <div class="tcard reveal"><span class="tcard-qicon"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M7 7h4v6c0 2.2-1.4 3.6-3.6 4l-.4-1.5C8.3 15 9 14.3 9 13H7V7zm7 0h4v6c0 2.2-1.4 3.6-3.6 4l-.4-1.5c1.3-.5 2-1.2 2-2.5h-2V7z"/></svg></span><p>{{excerpt words="38"}}</p><div class="tcard-author">{{#if feature_image}}<img src="{{img_url feature_image size="xs"}}" alt="{{title}}" />{{else}}<span class="ta-ph"><svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3.4" stroke="currentColor" stroke-width="1.7"/><path d="M5 20c0-3.3 3.1-5.5 7-5.5s7 2.2 7 5.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg></span>{{/if}}<div><b>{{title}}</b><span>Beneficiary</span></div></div></div>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- Image album --}}
{{#get "posts" filter="tag:sevadhama-album" limit="8" order="published_at desc" as |album|}}
    {{#if album}}
    <section class="section">
        <div class="container">
            <div class="section-head center reveal"><span class="eyebrow center">Gallery</span><h2>Moments from Sevadhama</h2></div>
            <div class="album-grid reveal">
                {{#foreach album}}
                <div class="album-item{{#if @first}} wide{{/if}}">
                    {{#if feature_image}}<img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy" />{{else}}<div class="album-ph a{{@number}}"><svg width="32" height="32" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><circle cx="9" cy="10" r="1.6" stroke="currentColor" stroke-width="1.5"/><path d="M5 18l5-4 4 3 2-2 3 3" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg></div>{{/if}}
                    <span class="album-cap">{{title}}</span>
                </div>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- Video stories (posts tagged sevadhama-video): thumbnail = feature image, video + text from body --}}
{{#get "posts" filter="tag:sevadhama-video" limit="10" order="published_at asc" as |vids|}}
    {{#if vids}}
    <section class="section pv-section">
        <div class="container">
            <div class="section-head center reveal"><span class="eyebrow center">Watch</span><h2>Stories in motion</h2></div>
            <div class="pv-list">
                {{#foreach vids}}
                <div class="pv-card reveal">
                    <div class="pv-media">
                        {{#if feature_image}}<img src="{{img_url feature_image size="l"}}" alt="{{title}}" loading="lazy" />{{else}}<div class="pv-ph"></div>{{/if}}
                        <button class="pv-play" type="button" aria-label="Play video"><svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></button>
                        <div class="pv-embed"></div>
                    </div>
                    <div class="pv-text">
                        <h3>{{title}}</h3>
                        <div class="pv-desc"></div>
                    </div>
                    <div class="pv-source" hidden>{{content}}</div>
                </div>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- Body gallery (auto-built from a Gallery card in the page body) — home-style bento --}}
<section class="section flush-top prog-gallery" hidden>
    <div class="container">
        <div class="shead-minimal reveal"><span class="shead-label">Gallery</span><h2>Glimpses of our work</h2></div>
        <div class="home-gallery">
            <div class="gallery-source"></div>
            <div class="gallery-rect">
                <button class="g-arrow prev" type="button" aria-label="Previous" hidden><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                <div class="gallery-bento"></div>
                <button class="g-arrow next" type="button" aria-label="Next" hidden><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
            </div>
        </div>
    </div>
</section>

{{!-- Wound Care highlight --}}
<section class="section-sm">
    <div class="container">
        <div class="cta-card reveal" style="background:var(--grad-cool); text-align:left;">
            <span class="pill" style="background:rgba(255,255,255,0.2); color:#fff;">New &middot; 2025</span>
            <h2 style="margin-top:16px;">Wound Care &amp; Rehabilitation Centre, Byndoor</h2>
            <p style="margin-left:0;">A specialised facility treating chronic wounds, pressure sores, diabetic foot ulcers and spinal cord injury–related wounds — combining medical treatment, nursing, physiotherapy, nutrition and counselling under one multidisciplinary team.</p>
        </div>
    </div>
</section>

{{/post}}
