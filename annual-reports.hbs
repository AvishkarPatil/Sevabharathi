{{!< default}}

<header class="tag-header">
    <div class="container">
        <span class="pill">Annual Reports</span>
        <h1>Annual reports</h1>
        <p>Our yearly impact and accounts, published transparently. Open any report to read it.</p>
    </div>
</header>

<section class="section">
    <div class="container">
        {{#if posts}}
        <div class="nl-grid">
            {{#foreach posts}}
            <div class="nl-card" data-url="{{url}}" role="button" tabindex="0" aria-label="Open {{title}}">
                <div class="nl-cover">
                    {{#if feature_image}}<img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy" />{{else}}<div class="nl-cover-ph"><svg width="46" height="46" viewBox="0 0 24 24" fill="none"><path d="M14 3H7a2 2 0 00-2 2v14a2 2 0 002 2h10a2 2 0 002-2V8l-5-5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M14 3v5h5M9 13h6M9 17h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></div>{{/if}}
                </div>
                <div class="nl-title">{{title}}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div class="nl-source">{{content}}</div>
            </div>
            {{/foreach}}
        </div>

        {{#if pagination.pages}}
        <nav class="pagination" role="navigation">
            {{#if pagination.prev}}<a href="{{page_url pagination.prev}}"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M19 12H5M11 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> Newer</a>{{/if}}
            <span class="page-number">Page {{pagination.page}} of {{pagination.pages}}</span>
            {{#if pagination.next}}<a href="{{page_url pagination.next}}">Older <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>{{/if}}
        </nav>
        {{/if}}

        {{else}}
        <p class="empty-note">No annual reports yet. Add posts tagged <strong>annual-report</strong> (PDF as a File card in the body — the card shows the first page automatically).</p>
        {{/if}}
    </div>
</section>
