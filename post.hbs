{{!< default}}
{{#post}}
<article class="post {{post_class}}">

{{#has tag="event"}}
    {{!-- EVENT DETAIL --}}
    <header class="page-hero center">
        <div class="container">
            <div class="page-hero-inner reveal">
                <nav class="breadcrumb"><a href="{{@site.url}}">Home</a> <span>/</span> <a href="/events/">Events</a> <span>/</span> <span>{{title}}</span></nav>
                <span class="eyebrow center">Event</span>
                <h1>{{title}}</h1>
                <div class="event-meta-row">
                    <span><svg width="17" height="17" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M3 9h18M8 3v4M16 3v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>{{date published_at format="DD MMMM YYYY"}}</span>
                </div>
                {{#if og_title}}<a href="{{og_title}}" target="_blank" rel="noopener" class="btn btn-primary btn-lg">Register Now <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H8M17 7v9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>{{/if}}
            </div>
        </div>
    </header>
    {{#if feature_image}}
    <div class="container" style="margin-top:-26px; position:relative; z-index:2;">
        <div class="activity-detail-img reveal"><img src="{{img_url feature_image size="xl"}}" alt="{{title}}" /></div>
    </div>
    {{/if}}
    <section class="section">
        <div class="container">
            <div class="post-content" style="margin:0 auto;">{{content}}</div>
        </div>
    </section>
    {{#if og_title}}
    <section class="section-sm">
        <div class="container">
            <div class="cta-card reveal">
                <h2>Ready to join us?</h2>
                <p>Register for this event and be part of the change.</p>
                <div class="cta-actions">
                    <a href="{{og_title}}" target="_blank" rel="noopener" class="btn btn-light btn-lg">Register Now</a>
                    <a href="/contact/" class="btn btn-ghost-light btn-lg">Contact Us</a>
                </div>
            </div>
        </div>
    </section>
    {{/if}}
{{else}}

    {{!-- Split hero --}}
    <header class="post-hero">
        <div class="container">
            <div class="post-hero-grid">
                <div class="post-hero-content reveal">
                    <nav class="breadcrumb"><a href="{{@site.url}}">Home</a> <span>/</span> {{#primary_tag}}<a href="{{url}}">{{name}}</a>{{else}}<span>Story</span>{{/primary_tag}}</nav>
                    {{#primary_tag}}<span class="pill">{{name}}</span>{{/primary_tag}}
                    <h1>{{title}}</h1>
                    {{#if custom_excerpt}}<p class="post-excerpt">{{custom_excerpt}}</p>{{/if}}
                    <div class="post-meta">
                        {{#primary_author}}
                            {{#if profile_image}}
                                <img class="author-img" src="{{img_url profile_image size="xs"}}" alt="{{name}}" />
                            {{else}}
                                <span class="author-ph"><svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3.4" stroke="currentColor" stroke-width="1.7"/><path d="M5 20c0-3.3 3.1-5.5 7-5.5s7 2.2 7 5.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg></span>
                            {{/if}}
                            <div>
                                <span class="author-name">{{name}}</span><br>
                                <span class="post-date">{{date published_at format="DD MMMM YYYY"}} &middot; {{reading_time}}</span>
                            </div>
                        {{/primary_author}}
                    </div>
                </div>
                <div class="post-hero-image reveal reveal-delay-1">
                    {{#if feature_image}}
                        <img src="{{img_url feature_image size="l"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" />
                    {{else}}
                        <div class="post-hero-image-ph"><svg width="60" height="60" viewBox="0 0 24 24" fill="none"><path d="M12 21s-7-4.35-9.5-9C1 9 2.5 5 6 5c2 0 3.2 1.2 4 2.5C10.8 6.2 12 5 14 5c3.5 0 5 4 3.5 7C19 16.65 12 21 12 21z" stroke="currentColor" stroke-width="1.4"/></svg></div>
                    {{/if}}
                </div>
            </div>
        </div>
    </header>

    {{!-- Body --}}
    <section class="section">
        <div class="container">
            <div class="post-layout">
                {{!-- Share rail --}}
                <aside class="post-share">
                    <a href="https://twitter.com/intent/tweet?url={{url absolute="true"}}&text={{encode title}}" target="_blank" rel="noopener" aria-label="Share on X">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h3l-7 8 8 12h-6l-5-7-6 7H2l8-9L2 2h6l4 6 6-6z"/></svg>
                    </a>
                    <a href="https://www.facebook.com/sharer/sharer.php?u={{url absolute="true"}}" target="_blank" rel="noopener" aria-label="Share on Facebook">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M14 9h3V5h-3c-2.2 0-4 1.8-4 4v2H7v4h3v7h4v-7h3l1-4h-4V9c0-.6.4-1 1-1z"/></svg>
                    </a>
                    <a href="https://www.linkedin.com/sharing/share-offsite/?url={{url absolute="true"}}" target="_blank" rel="noopener" aria-label="Share on LinkedIn">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M6.5 8H3v13h3.5V8zM4.75 3a2 2 0 100 4 2 2 0 000-4zM21 21h-3.5v-6.8c0-1.7-.6-2.8-2.1-2.8-1.1 0-1.8.8-2 1.5-.1.3-.1.6-.1 1V21H9.8s.05-11.8 0-13H13.3v1.8c.5-.7 1.3-1.8 3.2-1.8 2.4 0 4.5 1.6 4.5 4.9V21z"/></svg>
                    </a>
                    <a href="https://wa.me/?text={{encode title}}%20{{url absolute="true"}}" target="_blank" rel="noopener" aria-label="Share on WhatsApp">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 00-8.6 15l-1.3 4.8 5-1.3A10 10 0 1012 2zm4.4 12c-.2-.1-1.4-.7-1.6-.8-.2-.1-.4-.1-.5.1-.2.2-.6.8-.7.9-.1.1-.3.2-.5.1-1.4-.7-2.3-1.3-3.3-2.9-.2-.4.2-.4.6-1.2.1-.1 0-.3 0-.4l-.7-1.7c-.2-.5-.4-.4-.5-.4h-.5c-.2 0-.4.1-.6.3-.8.8-.9 1.9-.5 3 .5 1.4 1.5 2.6 2.9 3.7 1.9 1.4 3.2 1.3 4 1.2.5-.1 1.4-.6 1.6-1.1.2-.5.2-1 .1-1.1l-.5-.5z"/></svg>
                    </a>
                </aside>

                {{!-- Content --}}
                <div class="post-content">
                    {{content}}
                </div>

                {{!-- Sidebar --}}
                <aside class="post-sidebar">
                    <div class="widget widget-about">
                        <h4>About {{@site.title}}</h4>
                        <p>{{@site.description}}</p>
                        <a href="/about/" class="btn-link" style="margin-top:14px;">Read more
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </a>
                    </div>

                    {{#has tag="blog"}}
                    {{#get "posts" filter="tag:blog+id:-{{id}}" limit="4" as |featured|}}
                        {{#if featured}}
                        <div class="widget widget-posts">
                            <h4>More Posts</h4>
                            {{#foreach featured}}
                            <a href="{{url}}">
                                {{#if feature_image}}<img src="{{img_url feature_image size="xs"}}" alt="{{title}}" />{{else}}<span class="wp-ph"></span>{{/if}}
                                <span class="wp-title">{{title}}</span>
                            </a>
                            {{/foreach}}
                        </div>
                        {{/if}}
                    {{/get}}
                    {{else}}
                    {{#get "posts" filter="tag:success-stories+id:-{{id}}" limit="4" as |featured|}}
                        {{#if featured}}
                        <div class="widget widget-posts">
                            <h4>More Stories</h4>
                            {{#foreach featured}}
                            <a href="{{url}}">
                                {{#if feature_image}}<img src="{{img_url feature_image size="xs"}}" alt="{{title}}" />{{else}}<span class="wp-ph"></span>{{/if}}
                                <span class="wp-title">{{title}}</span>
                            </a>
                            {{/foreach}}
                        </div>
                        {{/if}}
                    {{/get}}
                    {{/has}}

                    {{#if tags}}
                    <div class="widget">
                        <h4>Tags</h4>
                        <div class="tag-cloud">
                            {{#foreach tags}}<a href="{{url}}">{{name}}</a>{{/foreach}}
                        </div>
                    </div>
                    {{/if}}
                </aside>
            </div>
        </div>
    </section>

    {{!-- Related (blogs for blog posts, stories otherwise) --}}
    {{#has tag="blog"}}
    {{#get "posts" filter="tag:blog+id:-{{id}}" limit="3" order="published_at desc" as |related|}}
        {{#if related}}
        <section class="section bg-soft">
            <div class="container">
                <div class="section-head center reveal rel-head">
                    <span class="eyebrow center">Keep Reading</span>
                    <h2>Related posts</h2>
                </div>
                <div class="card-grid">
                    {{#foreach related}}{{> "post-card"}}{{/foreach}}
                </div>
            </div>
        </section>
        {{/if}}
    {{/get}}
    {{else}}
    {{#get "posts" filter="tag:success-stories+id:-{{id}}" limit="3" order="published_at desc" as |related|}}
        {{#if related}}
        <section class="section bg-soft">
            <div class="container">
                <div class="section-head center reveal rel-head">
                    <span class="eyebrow center">Keep Reading</span>
                    <h2>Related stories</h2>
                </div>
                <div class="card-grid">
                    {{#foreach related}}{{> "post-card"}}{{/foreach}}
                </div>
            </div>
        </section>
        {{/if}}
    {{/get}}
    {{/has}}
{{/has}}

</article>
{{/post}}
