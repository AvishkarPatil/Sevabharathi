{{!< default}}
{{#post}}

<header class="page-hero center">
    <div class="container">
        <div class="page-hero-inner reveal">
            <nav class="breadcrumb"><a href="{{@site.url}}">Home</a> <span>/</span> <span>{{title}}</span></nav>
            <h1>{{title}}</h1>
            {{#if custom_excerpt}}<p>{{custom_excerpt}}</p>{{else}}<p>Three focused programmes addressing rehabilitation, women empowerment and community health.</p>{{/if}}
        </div>
    </div>
</header>

{{#if content}}
<section class="section-sm">
    <div class="container">
        <div class="post-content reveal" style="margin:0 auto;">{{content}}</div>
    </div>
</section>
{{/if}}

<section class="section">
    <div class="container">
        <div class="grid grid-3">
            {{#get "pages" filter="tag:home-programs" limit="3" order="published_at asc" as |programs|}}
                {{#if programs}}
                    {{#foreach programs}}
                    <a href="{{#if og_title}}{{og_title}}{{else}}{{url}}{{/if}}" class="program-card reveal">
                        <div class="program-card-img">
                            {{#if feature_image}}<img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy" />{{else}}<div class="program-card-ph"><svg width="48" height="48" viewBox="0 0 24 24" fill="none"><path d="M12 21s-7-4.35-9.5-9C1 9 2.5 5 6 5c2 0 3.2 1.2 4 2.5C10.8 6.2 12 5 14 5c3.5 0 5 4 3.5 7C19 16.65 12 21 12 21z" stroke="currentColor" stroke-width="1.5"/></svg></div>{{/if}}
                            <span class="program-card-num">{{@number}}</span>
                        </div>
                        <div class="program-card-body">
                            <h3>{{title}}</h3>
                            <p>{{excerpt words="26"}}</p>
                            <span class="btn-link">Learn More <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                        </div>
                    </a>
                    {{/foreach}}
                {{else}}
                    <a href="/sevadhama/" class="program-card reveal">
                        <div class="program-card-img"><div class="program-card-ph"><svg width="48" height="48" viewBox="0 0 24 24" fill="none"><path d="M5 11h14M7 11V7a5 5 0 0110 0v4M6 11l1 9h10l1-9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><span class="program-card-num">1</span></div>
                        <div class="program-card-body"><h3>Sevadhama</h3><p>Residential rehabilitation centre for persons with spinal cord injury at Southadka — a structured 12-week programme of therapy, life skills and livelihood.</p><span class="btn-link">Learn More <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span></div>
                    </a>
                    <a href="/sabalini/" class="program-card reveal reveal-delay-1">
                        <div class="program-card-img"><div class="program-card-ph"><svg width="48" height="48" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3.4" stroke="currentColor" stroke-width="1.5"/><path d="M5 20c0-3.5 3.1-6 7-6s7 2.5 7 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div><span class="program-card-num">2</span></div>
                        <div class="program-card-body"><h3>Sabalini</h3><p>Rural women empowerment since 2006 through free tailoring camps, skill development and self-employment support across Belthangady taluk.</p><span class="btn-link">Learn More <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span></div>
                    </a>
                    <a href="/arogyam/" class="program-card reveal reveal-delay-2">
                        <div class="program-card-img"><div class="program-card-ph"><svg width="48" height="48" viewBox="0 0 24 24" fill="none"><path d="M3 12h4l2-5 4 10 2-5h6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg></div><span class="program-card-num">3</span></div>
                        <div class="program-card-body"><h3>Arogyam</h3><p>Community health since 2008 — free health camps, blood donation drives and 24/7 affordable ambulance services for rural communities.</p><span class="btn-link">Learn More <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span></div>
                    </a>
                {{/if}}
            {{/get}}
        </div>
    </div>
</section>

<section class="section bg-soft cta-banner">
    <div class="container">
        <div class="cta-card reveal">
            <h2>See the difference together</h2>
            <p>Discover the measurable impact our programmes have created across coastal Karnataka.</p>
            <div class="cta-actions">
                <a href="/impact/" class="btn btn-light btn-lg">Our Impact</a>
                <a href="/donate/" class="btn btn-ghost-light btn-lg">Support a Programme</a>
            </div>
        </div>
    </div>
</section>

{{/post}}
