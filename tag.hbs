{{!< default}}
{{#tag}}
<header class="tag-header">
    <div class="container">
        <span class="pill">Archive</span>
        <h1>{{name}}</h1>
        {{#if description}}<p>{{description}}</p>{{/if}}
    </div>
</header>
{{/tag}}

<section class="section">
    <div class="container">
        {{#if posts}}
        <div class="card-grid">
            {{#foreach posts}}
                {{> "post-card"}}
            {{/foreach}}
        </div>

        {{#if pagination.pages}}
        <nav class="pagination" role="navigation">
            {{#if pagination.prev}}
            <a href="{{page_url pagination.prev}}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M19 12H5M11 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Newer
            </a>
            {{/if}}
            <span class="page-number">Page {{pagination.page}} of {{pagination.pages}}</span>
            {{#if pagination.next}}
            <a href="{{page_url pagination.next}}">Older
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            {{/if}}
        </nav>
        {{/if}}

        {{else}}
        <p class="empty-note">No posts found in this archive yet.</p>
        {{/if}}
    </div>
</section>
