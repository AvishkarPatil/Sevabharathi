{{!< default}}
{{#post}}

<header class="page-hero center">
    <div class="container">
        <div class="page-hero-inner reveal">
            <nav class="breadcrumb"><a href="{{@site.url}}">Home</a> <span>/</span> <span>{{title}}</span></nav>
            <h1>{{title}}</h1>
            {{#if custom_excerpt}}<p>{{custom_excerpt}}</p>{{else}}<p>Two decades of measurable change across coastal Karnataka.</p>{{/if}}
        </div>
    </div>
</header>

{{!-- Big stats grid — dynamic from a table (id | name | number) in the page body; static fallback below.
     "id" must match an icon filename in assets/impact-icons (without .png), e.g. wheelchair, ambulance. --}}
<section class="section">
    <div class="container">
        <div class="impact-source" hidden>{{content}}</div>
        <div class="impact-grid-wrap reveal">
            <div class="impact-icons-grid" id="impact-grid" data-iconbase="{{asset "impact-icons/search.png"}}">
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/search.png"}}" alt="Identified" loading="lazy"></span><span class="num" data-target="833">833</span><span class="lbl">Identified People with Spinal Cord Injury</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/rehabilitation.png"}}" alt="Rehabilitated" loading="lazy"></span><span class="num" data-target="279">279</span><span class="lbl">Rehabilitated People with Spinal Cord Injury</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/medical-camp.png"}}" alt="Medical camps" loading="lazy"></span><span class="num" data-target="31">31</span><span class="lbl">Medical Camps Held</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/wheelchair.png"}}" alt="Wheelchairs" loading="lazy"></span><span class="num" data-target="438">438</span><span class="lbl">Wheelchairs Distributed</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/walking-stick.png"}}" alt="Calipers" loading="lazy"></span><span class="num" data-target="64">64</span><span class="lbl">Calipers Provided</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/mobility-aids.png"}}" alt="Walkers" loading="lazy"></span><span class="num" data-target="90">90</span><span class="lbl">Walkers Given</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/home-accessibility.png"}}" alt="Home accessibility" loading="lazy"></span><span class="num" data-target="52">52</span><span class="lbl">Home Accessibility (Ramps, Toilets)</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/self-employed.png"}}" alt="Self employment" loading="lazy"></span><span class="num" data-target="140">140</span><span class="lbl">Assistance for Self-Employment</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/medical-intervention.png"}}" alt="Medical intervention" loading="lazy"></span><span class="num" data-target="326">326</span><span class="lbl">Medical Interventions</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/surgical-assistance.png"}}" alt="Surgical assistance" loading="lazy"></span><span class="num" data-target="16">16</span><span class="lbl">Surgical Assistance</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/hospital-visited.png"}}" alt="Hospitals visited" loading="lazy"></span><span class="num" data-target="163">163</span><span class="lbl">Hospitals Visited (PHC, CHC, THC)</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/panchayats-visited.png"}}" alt="Panchayats visited" loading="lazy"></span><span class="num" data-target="100">100</span><span class="lbl">Panchayats Visited</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/medical-kit.png"}}" alt="Medical kits" loading="lazy"></span><span class="num" data-target="1,769">1,769</span><span class="lbl">Medical / Self-Care Kits Distributed</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/grocery-kit.png"}}" alt="Grocery kits" loading="lazy"></span><span class="num" data-target="343">343</span><span class="lbl">Grocery Kits Distributed</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/solar-inverter.png"}}" alt="Solar inverters" loading="lazy"></span><span class="num" data-target="46">46</span><span class="lbl">Solar Inverters</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/diabetic-machines.png"}}" alt="BP/Diabetic machines" loading="lazy"></span><span class="num" data-target="107">107</span><span class="lbl">BP / Diabetic Machines</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/taluka-covered.png"}}" alt="Taluks covered" loading="lazy"></span><span class="num" data-target="48">48</span><span class="lbl">Taluks Covered</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/blood-donation-camp.png"}}" alt="Blood donation camps" loading="lazy"></span><span class="num" data-target="105">105</span><span class="lbl">Blood Donation Camps Organised</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/blood-units.png"}}" alt="Blood units" loading="lazy"></span><span class="num" data-target="11,399">11,399</span><span class="lbl">Units of Blood Collected</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/ambulance.png"}}" alt="Ambulance" loading="lazy"></span><span class="num" data-target="403">403</span><span class="lbl">Ambulance Services</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/sewing-machine.png"}}" alt="Tailoring camps" loading="lazy"></span><span class="num" data-target="36">36</span><span class="lbl">Tailoring Camps</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/women-empowered.png"}}" alt="Women empowered" loading="lazy"></span><span class="num" data-target="967">967</span><span class="lbl">Women Empowered</span></div>
            </div>
        </div>
    </div>
</section>

{{!-- Program-wise breakdown --}}
<section class="section bg-soft">
    <div class="container">
        <div class="section-head center reveal">
            <span class="eyebrow center">By Programme</span>
            <h2>Impact across our three pillars</h2>
        </div>
        <div class="grid grid-3">
            <div class="feature-card reveal">
                <span class="feature-icon"><svg width="26" height="26" viewBox="0 0 24 24" fill="none"><path d="M5 11h14M7 11V7a5 5 0 0110 0v4M6 11l1 9h10l1-9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                <h3>Sevadhama</h3>
                <p>Residential rehabilitation restoring mobility and dignity — wheelchairs, mobility aids, home accessibility and livelihood support for PwSCI.</p>
                <a href="/sevadhama/" class="btn-link" style="margin-top:14px;">Explore programme <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            </div>
            <div class="feature-card reveal reveal-delay-1">
                <span class="feature-icon blue"><svg width="26" height="26" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3.4" stroke="currentColor" stroke-width="1.5"/><path d="M5 20c0-3.5 3.1-6 7-6s7 2.5 7 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span>
                <h3>Sabalini</h3>
                <p>Free tailoring camps and skill development empowering rural women to earn with dignity and lift their families out of poverty.</p>
                <a href="/sabalini/" class="btn-link" style="margin-top:14px;">Explore programme <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            </div>
            <div class="feature-card reveal reveal-delay-2">
                <span class="feature-icon teal"><svg width="26" height="26" viewBox="0 0 24 24" fill="none"><path d="M3 12h4l2-5 4 10 2-5h6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                <h3>Arogyam</h3>
                <p>Health camps, blood donation drives and 24/7 ambulance services keeping rural communities healthy and safe.</p>
                <a href="/arogyam/" class="btn-link" style="margin-top:14px;">Explore programme <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            </div>
        </div>
    </div>
</section>

{{!-- Success stories --}}
<section class="section">
    <div class="container">
        <div class="section-head center reveal"><span class="eyebrow center">Real Lives</span><h2>Stories behind the numbers</h2></div>
        {{#get "posts" filter="tag:success-stories" limit="3" order="published_at desc" as |stories|}}
            {{#if stories}}
            <div class="card-grid">
                {{#foreach stories}}{{> "post-card"}}{{/foreach}}
            </div>
            <div style="text-align:center; margin-top:48px;" class="reveal"><a href="/tag/success-stories/" class="btn btn-outline btn-lg">View all stories</a></div>
            {{else}}
            <p class="empty-note">Success stories will appear here once published with the <strong>success-stories</strong> tag.</p>
            {{/if}}
        {{/get}}
    </div>
</section>

<section class="section cta-banner">
    <div class="container">
        <div class="cta-card reveal">
            <h2>Help us reach further</h2>
            <p>Your support turns these numbers into more lives restored and empowered.</p>
            <div class="cta-actions">
                <a href="/donate/" class="btn btn-light btn-lg">Donate Now</a>
                <a href="/get-involved/" class="btn btn-ghost-light btn-lg">Get Involved</a>
            </div>
        </div>
    </div>
</section>

{{/post}}
