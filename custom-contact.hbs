{{!< default}}
{{#post}}

<header class="page-hero center">
    <div class="container">
        <div class="page-hero-inner reveal">
            <nav class="breadcrumb"><a href="{{@site.url}}">Home</a> <span>/</span> <span>{{title}}</span></nav>
            <h1>{{title}}</h1>
            {{#if custom_excerpt}}<p>{{custom_excerpt}}</p>{{else}}<p>We'd love to hear from you. Reach out across any of our centres.</p>{{/if}}
        </div>
    </div>
</header>

{{!-- Office cards --}}
<section class="section">
    <div class="container">
        <div class="grid grid-3">
            {{#if @custom.contact_address_main}}
            <div class="contact-card reveal">
                <span class="cc-icon"><img src="{{asset "contact/office.svg"}}" alt="Administrative Office" /></span>
                <h3>Administrative Office</h3>
                <p>{{@custom.contact_address_main}}</p>
            </div>
            {{/if}}
            {{#if @custom.contact_address_southadka}}
            <div class="contact-card reveal reveal-delay-1">
                <span class="cc-icon"><img src="{{asset "contact/center.svg"}}" alt="Sevadhama Rehab Centre" /></span>
                <h3>Sevadhama Rehab Centre</h3>
                <p>{{@custom.contact_address_southadka}}</p>
            </div>
            {{/if}}
            {{#if @custom.contact_address_byndoor}}
            <div class="contact-card reveal reveal-delay-2">
                <span class="cc-icon"><img src="{{asset "contact/Wound-Care-Centre.svg"}}" alt="Wound Care Centre, Byndoor" /></span>
                <h3>Wound Care Centre, Byndoor</h3>
                <p>{{@custom.contact_address_byndoor}}</p>
            </div>
            {{/if}}
        </div>

        {{!-- Email & phone --}}
        <div class="contact-meta-grid" style="margin-top:28px;">
            {{#if @custom.contact_phone}}
            <a href="tel:{{@custom.contact_phone}}" class="contact-line reveal">
                <span class="cl-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M5 4h3l2 5-2 1c1 2 2.5 3.5 4.5 4.5l1-2 5 2v3c0 1-1 2-2 2A16 16 0 013 6c0-1 1-2 2-2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg></span>
                <span><span class="cl-label">Call us</span><br><span class="cl-value">{{@custom.contact_phone}}</span></span>
            </a>
            {{/if}}
            {{#if @custom.contact_email}}
            <a href="mailto:{{@custom.contact_email}}" class="contact-line reveal reveal-delay-1">
                <span class="cl-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M3 7l9 6 9-6" stroke="currentColor" stroke-width="1.6"/></svg></span>
                <span><span class="cl-label">Email us</span><br><span class="cl-value">{{@custom.contact_email}}</span></span>
            </a>
            {{/if}}
        </div>
    </div>
</section>

{{!-- Map + Form --}}
<section class="section bg-soft">
    <div class="container">
        <div class="donate-grid">
            <div class="reveal">
                <span class="eyebrow">Find Us</span>
                <h2 style="margin-bottom:24px; font-size:clamp(1.4rem, 2.3vw, 1.8rem);">Visit our office</h2>
                {{#if @custom.contact_map_embed_url}}
                <div class="map-wrapper">
                    <iframe src="{{@custom.contact_map_embed_url}}" height="420" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Map"></iframe>
                </div>
                {{else}}
                <div class="map-wrapper" style="background:var(--color-bg-muted); height:420px; display:grid; place-items:center; color:var(--color-text-muted);">
                    <div style="text-align:center;"><svg width="48" height="48" viewBox="0 0 24 24" fill="none"><path d="M12 21s7-5.5 7-11a7 7 0 10-14 0c0 5.5 7 11 7 11z" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg><p style="margin-top:12px;">Map will appear here once configured.</p></div>
                </div>
                {{/if}}
            </div>

            <div class="contact-form reveal reveal-delay-1">
                <h3 style="margin-bottom:20px;">Send us a message</h3>
                <form action="mailto:{{@custom.contact_email}}" method="post" enctype="text/plain">
                    <div class="form-row"><label for="cf-name">Name</label><input id="cf-name" type="text" name="Name" placeholder="Your full name" required></div>
                    <div class="form-row"><label for="cf-email">Email</label><input id="cf-email" type="email" name="Email" placeholder="you@example.com" required></div>
                    <div class="form-row"><label for="cf-phone">Phone</label><input id="cf-phone" type="tel" name="Phone" placeholder="Your phone number"></div>
                    <div class="form-row"><label for="cf-msg">Message</label><textarea id="cf-msg" name="Message" placeholder="How can we help?" required></textarea></div>
                    <button type="submit" class="btn btn-primary btn-lg" style="width:100%;">Send Message
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>

{{/post}}
