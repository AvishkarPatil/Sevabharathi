{{!< default}}
{{#post}}

<div class="prog-source" hidden>{{content}}</div>

<header class="page-hero center">
    <div class="container">
        <div class="page-hero-inner reveal">
            <nav class="breadcrumb"><a href="{{@site.url}}">Home</a> <span>/</span> <a href="/programs/">Programs</a> <span>/</span> <span>{{title}}</span></nav>
            <span class="eyebrow center">Women Empowerment</span>
            <h1>{{title}}</h1>
            <p>{{#if custom_excerpt}}{{custom_excerpt}}{{else}}Empowering rural women through skill development since 2006.{{/if}}</p>
        </div>
    </div>
</header>

<section class="section">
    <div class="container">
        <div class="split">
            <div class="split-media reveal">
                {{#if feature_image}}<img src="{{img_url feature_image size="l"}}" alt="{{title}}" />{{else}}<div class="split-media-ph"><svg width="56" height="56" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3.4" stroke="currentColor" stroke-width="1.4"/><path d="M5 20c0-3.5 3.1-6 7-6s7 2.5 7 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg></div>{{/if}}
            </div>
            <div class="split-body reveal reveal-delay-1">
                <span class="eyebrow">About the Programme</span>
                <h2 class="prog-about-h">Building self-reliant women, stronger families</h2>
                <div class="prog-about-p">
                    <p>{{#if custom_excerpt}}{{custom_excerpt}}{{else}}Project Sabalini supports rural women and empowers them through free tailoring camps that build self-reliance. Health check-ups, awareness programmes and felicitation of women achievers motivate participants across the villages of Belthangady taluk.{{/if}}</p>
                    <p>Women reinvest up to 90% of their income into their families — making their empowerment one of the most powerful ways to break the cycle of poverty.</p>
                </div>
            </div>
        </div>
    </div>
</section>

{{!-- Focus areas --}}
<section class="section bg-soft prog-focus">
    <div class="container">
        <div class="section-head center reveal">
            <span class="eyebrow center">What We Offer</span>
            <h2>Focus areas</h2>
        </div>
        <div class="grid grid-3">
            {{#get "posts" filter="tag:sabalini-activities" limit="100" order="published_at asc" as |acts|}}
                {{#if acts}}
                    {{#foreach acts}}
                    <div class="feature-card reveal">
                        <span class="feature-icon">{{#if feature_image}}<img src="{{img_url feature_image size="xs"}}" alt="{{title}}" style="width:100%;height:100%;object-fit:cover;border-radius:14px;" />{{else}}<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5L20 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>{{/if}}</span>
                        <h3>{{title}}</h3>
                        <p>{{excerpt words="24"}}</p>
                    </div>
                    {{/foreach}}
                {{else}}
                    <div class="feature-card reveal"><span class="feature-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M6 3l3 3-9 9-3-3 9-9zM12 9l6 6M9 6l9 9 3-3-9-9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span><h3>Free Tailoring Camps</h3><p>Hands-on tailoring training camps organised in villages to equip women with a marketable, income-generating skill.</p></div>
                    <div class="feature-card reveal reveal-delay-1"><span class="feature-icon blue"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M3 12h4l2-5 4 10 2-5h6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg></span><h3>Health &amp; Awareness</h3><p>Awareness on hygiene, healthcare, home safety and parenting, with free health check-up camps for rural women.</p></div>
                    <div class="feature-card reveal reveal-delay-2"><span class="feature-icon teal"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M8 21h8M12 17v4M7 4h10v5a5 5 0 01-10 0V4z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span><h3>Self-Employment Support</h3><p>Encouraging income-generating activities and honouring women achievers to build lasting confidence.</p></div>
                {{/if}}
            {{/get}}
        </div>
    </div>
</section>

{{!-- Extra editable content (page body line 3 onwards) — full-width box, hidden until filled --}}
<section class="section prog-extra" hidden>
    <div class="container">
        <div class="prog-extra-box"><div class="prog-extra-body post-content"></div></div>
    </div>
</section>

{{!-- Apply band (label/description/link editable via Meta Title, Description, Canonical URL) --}}
<section class="section-sm pp-tight">
    <div class="container">
        <div class="apply-band reveal">
            <div class="apply-band-text">
                <h2>{{#if meta_title}}{{meta_title}}{{else}}Apply for Sabalini{{/if}}</h2>
                <p>{{#if meta_description}}{{meta_description}}{{else}}Join a free tailoring camp or partner with us to bring skill development and confidence to more rural women across Belthangady taluk.{{/if}}</p>
            </div>
            <div class="apply-band-actions">
                <a href="{{#if canonical_url}}{{canonical_url}}{{else}}{{@custom.donate_external_url}}{{/if}}" target="_blank" rel="noopener" class="btn btn-primary btn-lg">Apply Now <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H8M17 7v9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
                <a href="/contact/" class="btn btn-outline btn-lg">Contact Us</a>
            </div>
        </div>
    </div>
</section>

{{!-- Impact numbers --}}
<section class="section pp-tight">
    <div class="container">
        <div class="section-head center reveal"><span class="eyebrow center">Sabalini Impact</span><h2>What we have achieved</h2></div>
        <div class="impact-grid-wrap reveal" style="max-width:760px;margin:0 auto;">
            <div class="sabalini-impact-source" hidden>{{#get "posts" filter="tag:sabalini-impact" limit="1" as |rows|}}{{#foreach rows}}{{content}}{{/foreach}}{{/get}}</div>
            <div class="impact-icons-grid ig-3" id="sabalini-impact-grid" data-iconbase="{{asset "impact-icons/search.png"}}">
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/sewing-machine.png"}}" alt="Tailoring camps" loading="lazy"></span><span class="num" data-target="36">36</span><span class="lbl">Tailoring Camps Held</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/rural-women.png"}}" alt="Women trained" loading="lazy"></span><span class="num" data-target="967">967</span><span class="lbl">Women Trained</span></div>
                <div class="ic-stat"><span class="ic-stat-icon"><img src="{{asset "impact-icons/women-empowered.png"}}" alt="Families empowered" loading="lazy"></span><span class="num" data-target="1,107">1,107</span><span class="lbl">Families Empowered</span></div>
            </div>
        </div>
    </div>
</section>

{{!-- Success stories --}}
{{#get "posts" filter="tag:sabalini-stories" limit="3" order="published_at desc" as |stories|}}
    {{#if stories}}
    <section class="section bg-soft">
        <div class="container">
            <div class="section-head center reveal prog-mini"><span class="eyebrow center">Success Stories</span><h2>Women who changed their lives</h2></div>
            <div class="grid grid-3">
                {{#foreach stories}}
                <a href="{{url}}" class="story-card reveal"><div class="story-card-bg">{{#if feature_image}}<img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy" />{{else}}<div class="story-card-ph"></div>{{/if}}</div><div class="story-card-body"><span class="pill">Success Story</span><h3>{{title}}</h3><p>{{excerpt words="22"}}</p><span class="story-card-more">Read story <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span></div></a>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- Testimonials (program-specific) --}}
{{#get "posts" filter="tag:sabalini-testimonials" limit="3" order="published_at desc" as |quotes|}}
    {{#if quotes}}
    <section class="section bg-muted">
        <div class="container">
            <div class="section-head center reveal prog-mini"><span class="eyebrow center">In Their Words</span><h2>What women say</h2></div>
            <div class="grid grid-3">
                {{#foreach quotes}}
                <div class="tcard reveal"><span class="tcard-qicon"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M7 7h4v6c0 2.2-1.4 3.6-3.6 4l-.4-1.5C8.3 15 9 14.3 9 13H7V7zm7 0h4v6c0 2.2-1.4 3.6-3.6 4l-.4-1.5c1.3-.5 2-1.2 2-2.5h-2V7z"/></svg></span><p>{{excerpt words="38"}}</p><div class="tcard-author">{{#if feature_image}}<img src="{{img_url feature_image size="xs"}}" alt="{{title}}" />{{else}}<span class="ta-ph"><svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3.4" stroke="currentColor" stroke-width="1.7"/><path d="M5 20c0-3.3 3.1-5.5 7-5.5s7 2.2 7 5.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg></span>{{/if}}<div><b>{{title}}</b><span>Beneficiary</span></div></div></div>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- Album --}}
{{#get "posts" filter="tag:sabalini-album" limit="8" order="published_at desc" as |album|}}
    {{#if album}}
    <section class="section">
        <div class="container">
            <div class="section-head center reveal"><span class="eyebrow center">Gallery</span><h2>Moments from Sabalini</h2></div>
            <div class="album-grid reveal">
                {{#foreach album}}
                <div class="album-item{{#if @first}} wide{{/if}}">{{#if feature_image}}<img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy" />{{else}}<div class="album-ph a{{@number}}"><svg width="32" height="32" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><circle cx="9" cy="10" r="1.6" stroke="currentColor" stroke-width="1.5"/><path d="M5 18l5-4 4 3 2-2 3 3" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg></div>{{/if}}<span class="album-cap">{{title}}</span></div>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- Video stories (posts tagged sabalini-video) --}}
{{#get "posts" filter="tag:sabalini-video" limit="10" order="published_at asc" as |vids|}}
    {{#if vids}}
    <section class="section pv-section">
        <div class="container">
            <div class="section-head center reveal"><span class="eyebrow center">Watch</span><h2>Stories in motion</h2></div>
            <div class="pv-list">
                {{#foreach vids}}
                <div class="pv-card reveal">
                    <div class="pv-media">
                        {{#if feature_image}}<img src="{{img_url feature_image size="l"}}" alt="{{title}}" loading="lazy" />{{else}}<div class="pv-ph"></div>{{/if}}
                        <button class="pv-play" type="button" aria-label="Play video"><svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></button>
                        <div class="pv-embed"></div>
                    </div>
                    <div class="pv-text">
                        <h3>{{title}}</h3>
                        <div class="pv-desc"></div>
                    </div>
                    <div class="pv-source" hidden>{{content}}</div>
                </div>
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- Body gallery (auto-built from a Gallery card in the page body) — home-style bento --}}
<section class="section flush-top prog-gallery" hidden>
    <div class="container">
        <div class="shead-minimal reveal"><span class="shead-label">Gallery</span><h2>Glimpses of our work</h2></div>
        <div class="home-gallery">
            <div class="gallery-source"></div>
            <div class="gallery-rect">
                <button class="g-arrow prev" type="button" aria-label="Previous" hidden><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                <div class="gallery-bento"></div>
                <button class="g-arrow next" type="button" aria-label="Next" hidden><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
            </div>
        </div>
    </div>
</section>

<section class="section cta-banner pp-tight">
    <div class="container">
        <div class="cta-card reveal">
            <h2>Support women's empowerment</h2>
            <p>Help us bring skills, confidence and dignity to more rural women.</p>
            <div class="cta-actions">
                <a href="/donate/" class="btn btn-light btn-lg">Donate Now</a>
                <a href="/contact/" class="btn btn-ghost-light btn-lg">Contact Us</a>
            </div>
        </div>
    </div>
</section>

{{/post}}
